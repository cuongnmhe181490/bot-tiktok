generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  MOI
  DANG_TEST
  DANG_CHAY
  THANG
  LOAI_BO
}

enum TrendType {
  HOOK
  FORMAT
  SOUND
  GOC_NHIN
  KICH_BAN
  CHUYEN_DOI
}

enum ToneType {
  THUC_TE
  TINH_TE
  BAN_HANG_MEM
  CHIA_SE
  SO_SANH
  CANH_BAO
}

enum GoalType {
  TANG_CLICK
  TANG_DON
  TANG_WATCH_TIME
  TANG_TIN_CAY
  RE_TEST
}

enum VideoStatus {
  NHAP
  DA_DANG
  THANG
  KHONG_HIEU_QUA
  TAM_DUNG
}

enum SourceType {
  TIKTOK_CREATIVE_CENTER
  GOOGLE_TRENDS
  MANUAL
  CSV_IMPORT
  SYSTEM_DEMO
  INTERNAL_GENERATED
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum VerificationStatus {
  CHUA_XAC_MINH
  DA_DOI_CHIEU
  DU_LIEU_DEMO
}

model ScoringSettings {
  id                String   @id @default("scoring-default")
  easeWeight        Int      @default(20)
  competitionWeight Int      @default(20)
  saturationWeight  Int      @default(15)
  offerWeight       Int      @default(25)
  commissionWeight  Int      @default(20)
  updatedAt         DateTime @updatedAt
}

model DataSettings {
  id           String   @id @default("data-settings-default")
  freeOnlyMode Boolean  @default(true)
  showDemoData Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model Product {
  id                 String        @id @default(cuid())
  name               String
  slug               String        @unique
  productUrl         String
  source             String
  sourceType         SourceType    @default(MANUAL)
  collectedAt        DateTime?
  category           String
  originalPrice      Float
  salePrice          Float
  discountPercent    Int
  commissionPercent  Float
  estimatedCommission Float
  rating             Float
  reviewCount        Int
  shopName           String
  voucher            String?
  freeship           Boolean       @default(false)
  importedAt         DateTime
  lastVerifiedAt     DateTime?
  confidenceLevel    ConfidenceLevel @default(MEDIUM)
  verificationStatus VerificationStatus @default(CHUA_XAC_MINH)
  isDemo             Boolean       @default(false)
  notes              String?
  externalReferenceUrl String?
  shortDescription   String
  internalNote       String?
  status             ProductStatus @default(MOI)
  totalScore         Int
  easeOfFilming      Int
  competitionLevel   Int
  saturationLevel    Int
  offerAttractiveness Int
  scoreBreakdown     String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  scripts            ScriptDraft[]
  videos             VideoPerformance[]
}

model Trend {
  id                String             @id @default(cuid())
  name              String
  trendType         TrendType
  source            String
  sourceType        SourceType         @default(MANUAL)
  description       String
  suitableNiche     String
  externalReferenceUrl String?
  region            String?
  timeWindow        String?
  trendScore        Int?
  heatLevel         Int
  applicability     Int
  saturationLevel   Int
  discoveredAt      DateTime
  collectedAt       DateTime?
  importedAt        DateTime           @default(now())
  lastVerifiedAt    DateTime?
  confidenceLevel   ConfidenceLevel    @default(MEDIUM)
  verificationStatus VerificationStatus @default(CHUA_XAC_MINH)
  isDemo            Boolean            @default(false)
  notes             String?
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ScriptTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  structure   String
  tone        ToneType
  createdAt   DateTime @default(now())
  scripts     ScriptDraft[]
}

model ScriptDraft {
  id                String    @id @default(cuid())
  title             String
  audience          String
  painPoints        String
  strengths         String
  notes             String?
  tone              ToneType
  goal              GoalType
  durationSeconds   Int
  hooks             String
  angles            String
  voiceOvers        String
  shotLists         String
  captions          String
  ctas              String
  teleprompter      String
  subtitleReady     String
  safetyCheck       String
  bestVersion       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  productId         String
  templateId        String?
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  template          ScriptTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

model DraftProject {
  id               String    @id @default(cuid())
  title            String
  productName      String
  rawScript        String
  splitScript      String
  suggestedTiming  String
  sceneSuggestions String
  overlayTexts     String
  shootingChecklist String
  editingChecklist String
  scriptTxt        String
  subtitleSrt      String
  shotlistMd       String
  checklistMd      String
  metadataJson     String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model VideoPerformance {
  id              String      @id @default(cuid())
  title           String
  source          String
  sourceType      SourceType  @default(MANUAL)
  publishedAt     DateTime
  videoUrl        String
  collectedAt     DateTime?
  importedAt      DateTime    @default(now())
  lastVerifiedAt  DateTime?
  confidenceLevel ConfidenceLevel @default(MEDIUM)
  verificationStatus VerificationStatus @default(CHUA_XAC_MINH)
  isDemo          Boolean     @default(false)
  notes           String?
  externalReferenceUrl String?
  hook            String
  angle           String
  format          String
  durationSeconds Int
  captionType     String
  ctaType         String
  note            String?
  views           Int
  avgWatchTime    Float
  completionRate  Float
  clicks          Int
  ctr             Float
  orders          Int
  revenue         Float
  commission      Float
  status          VideoStatus @default(NHAP)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  productId       String
  productGroup    String
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}
